# Backend Environment Variables Template
# Copy this to .env and fill in your values

# Database Configuration (PostgreSQL via asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@your-db-host:5432/postgres

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Application Configuration
DEBUG=true
SECRET_KEY=your-secret-key-for-jwt

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# Model Configuration
MODEL_PATH=./models
MODEL_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO

# Supabase Authentication (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# HuggingFace Inference API (free — get token from https://huggingface.co/settings/tokens)
HF_TOKEN=
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# External Data APIs (optional — features work without them)
# OPENWEATHERMAP_API_KEY=         # Weather ingestion (https://openweathermap.org/api)
# FIRMS_API_KEY=                  # NASA fire data (https://firms.modaps.eosdis.nasa.gov)
# SENDGRID_API_KEY=               # Email alerts (https://sendgrid.com)
# SENDGRID_FROM_EMAIL=alerts@yourdomain.com
