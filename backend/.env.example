# Backend Environment Variables Template
# Copy this to .env and fill in your values

# Database Configuration (PostgreSQL via asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@your-db-host:5432/postgres

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Application Configuration
DEBUG=true
SECRET_KEY=your-secret-key-for-jwt

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# Model Configuration
MODEL_PATH=./models
MODEL_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO

# Supabase Authentication (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Groq API (required for AI API features)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# External Data APIs (optional — features work without them)
# -- OpenWeatherMap (free: 60 calls/min) ---------------------
# OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
# WEATHER_POLL_INTERVAL_S=600

# -- NASA FIRMS (free: NASA Earthdata account) ----------------
# FIRMS_API_KEY=your_firms_api_key_here
# FIRMS_POLL_INTERVAL_S=1800

# -- GDACS (no key needed - public RSS) ----------------------
# GDACS_POLL_INTERVAL_S=900

# -- USGS (no key needed - public GeoJSON) --------------------
# USGS_MIN_MAGNITUDE=4.0
# USGS_POLL_INTERVAL_S=300

# -- SendGrid (free: 100 emails/day) -------------------------
# SENDGRID_API_KEY=               # Email alerts (https://sendgrid.com)
# SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# -- Ingestion Settings ---------------------------------------
# INGESTION_ENABLED=true
# ALERT_SEVERITY_THRESHOLD=critical
# MAX_EVENTS_PER_POLL=50
